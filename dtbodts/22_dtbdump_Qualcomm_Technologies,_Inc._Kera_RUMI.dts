	fragment@51 {
		target = <0xffffffff>;

		__overlay__ {

			pmx_sde {
				phandle = <0x2b>;

				sde_dsi_active {
					phandle = <0x08>;

					mux {
						function = "gpio";
						pins = "gpio12";
					};

					config {
						bias-disable = <0x00>;
						drive-strength = <0x08>;
						pins = "gpio12";
					};
				};

				sde_dsi_suspend {
					phandle = <0x0a>;

					mux {
						function = "gpio";
						pins = "gpio12";
					};

					config {
						bias-pull-down;
						drive-strength = <0x02>;
						pins = "gpio12";
					};
				};

				sde_dsi1_active {
					phandle = <0x0c>;

					mux {
						function = "gpio";
						pins = "gpio127";
					};

					config {
						bias-disable = <0x00>;
						drive-strength = <0x08>;
						pins = "gpio127";
					};
				};

				sde_dsi1_suspend {
					phandle = <0x0e>;

					mux {
						function = "gpio";
						pins = "gpio127";
					};

					config {
						bias-pull-down;
						drive-strength = <0x02>;
						pins = "gpio127";
					};
				};
			};

			pmx_sde_te {
				phandle = <0x2c>;

				sde_te_active {
					phandle = <0x09>;

					mux {
						function = "mdp_vsync_p";
						pins = "gpio17";
					};

					config {
						bias-pull-down;
						drive-strength = <0x02>;
						pins = "gpio17";
					};
				};

				sde_te_suspend {
					phandle = <0x0b>;

					mux {
						function = "mdp_vsync_p";
						pins = "gpio17";
					};

					config {
						bias-pull-down;
						drive-strength = <0x02>;
						pins = "gpio17";
					};
				};

				sde_te1_active {
					phandle = <0x0d>;

					mux {
						function = "mdp_vsync_s";
						pins = "gpio121";
					};

					config {
						bias-pull-down;
						drive-strength = <0x02>;
						pins = "gpio121";
					};
				};

				sde_te1_suspend {
					phandle = <0x0f>;

					mux {
						function = "mdp_vsync_s";
						pins = "gpio121";
					};

					config {
						bias-pull-down;
						drive-strength = <0x02>;
						pins = "gpio121";
					};
				};
			};
		};
	};

	fragment@52 {
		target = <0xffffffff>;

		__overlay__ {

			dsi_panel_pwr_supply_sim {
