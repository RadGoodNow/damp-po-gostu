					reg = <0x00>;
				};

				qcom,panel-supply-entry@2 {
					qcom,supply-post-on-sleep = <0x00>;
					qcom,supply-disable-load = <0x50>;
					qcom,supply-enable-load = <0xed1c>;
					qcom,supply-max-voltage = <0x1312d0>;
