	fragment@15 {
		target = <0xffffffff>;

		__overlay__ {
			#address-cells = <0x02>;
			#size-cells = <0x00>;
			interrupt-controller;
			#interrupt-cells = <0x04>;

			qcom,pmd802x@4 {
				compatible = "qcom,spmi-pmic";
				reg = <0x04 0x00>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;

				pmd802x-temp-alarm@a00 {
					compatible = "qcom,spmi-temp-alarm";
					reg = <0xa00>;
					interrupts = <0x04 0x0a 0x00 0x03>;
					#thermal-sensor-cells = <0x00>;
					phandle = <0x0a>;
				};

				pinctrl@8800 {
					compatible = "qcom,pmd802x-gpio";
					reg = <0x8800>;
					gpio-controller;
					#gpio-cells = <0x02>;
					interrupt-controller;
					#interrupt-cells = <0x02>;
					phandle = <0x28>;
				};

				amoled-ecm@f900 {
					compatible = "qcom,amoled-ecm";
					reg = <0xf900>;
					nvmem-names = "amoled-ecm-sdam0", "amoled-ecm-sdam1", "amoled-ecm-sdam2";
					nvmem = <0xffffffff 0xffffffff 0xffffffff>;
					interrupt-names = "ecm-sdam0", "ecm-sdam1", "ecm-sdam2";
					interrupts = <0x00 0x7c 0x01 0x01 0x00 0x7d 0x01 0x01 0x00 0x98 0x01 0x01>;
				};

				qcom-amoled {
					compatible = "qcom,amoled-regulator";
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					nvmem-cells = <0xffffffff>;
					nvmem-cell-names = "ibb_spur_sqm_timer";
					status = "disabled";

					ibb@f800 {
						reg = <0xf800>;
						reg-names = "ibb_base";
						regulator-name = "ibb";
						regulator-min-microvolt = "", "\f5";
						regulator-max-microvolt = <0x895440>;
						regulator-allow-set-load;
						qcom,swire-control;
						phandle = <0x29>;
					};

					elvdd@f900 {
						reg = <0xf900>;
						reg-names = "ab_base";
						regulator-name = "ab";
						regulator-min-microvolt = <0x2625a0>;
						regulator-max-microvolt = <0x53ec60>;
						qcom,swire-control;
						phandle = <0x2a>;
					};

					oledb@fa00 {
						reg = <0xfa00>;
						reg-names = "oledb_base";
						regulator-name = "oledb";
						regulator-min-microvolt = <0x4c4b40>;
						regulator-max-microvolt = <0x7a1200>;
						qcom,swire-control;
						phandle = <0x2b>;
					};
				};
			};
		};
	};

