	fragment@74 {
		target = <0xffffffff>;

		__overlay__ {

			pmx_sde {
				phandle = <0x132>;

				sde_dsi_active {
					phandle = <0x101>;

					mux {
						function = "gpio";
						pins = "gpio14";
					};

					config {
						bias-disable = <0x00>;
						drive-strength = <0x08>;
						pins = "gpio14";
					};
				};

				sde_dsi_suspend {
					phandle = <0x103>;

					mux {
						function = "gpio";
						pins = "gpio14";
					};

					config {
						bias-pull-down;
						drive-strength = <0x02>;
						pins = "gpio14";
					};
				};

				sde_dsi1_active {
					phandle = <0x106>;

					mux {
						function = "gpio";
						pins = "gpio126";
					};

					config {
						bias-disable = <0x00>;
						drive-strength = <0x08>;
						pins = "gpio126";
					};
				};

				sde_dsi1_suspend {
					phandle = <0x108>;

					mux {
						function = "gpio";
						pins = "gpio126";
					};

					config {
						bias-pull-down;
						drive-strength = <0x02>;
						pins = "gpio126";
					};
				};
			};

			pmx_sde_te {
				phandle = <0x133>;

				sde_te_active {
					phandle = <0x102>;

					mux {
						function = "mdp_vsync_p";
						pins = "gpio77";
					};

					config {
						bias-pull-down;
						drive-strength = <0x02>;
						pins = "gpio77";
					};
				};

				sde_te_suspend {
					phandle = <0x104>;

					mux {
						function = "mdp_vsync_p";
						pins = "gpio77";
					};

					config {
						bias-pull-down;
						drive-strength = <0x02>;
						pins = "gpio77";
					};
				};

				sde_te1_active {
					phandle = <0x107>;

					mux {
						function = "mdp_vsync_s";
						pins = "gpio78";
					};

					config {
						bias-pull-down;
						drive-strength = <0x02>;
						pins = "gpio78";
					};
				};

				sde_te1_suspend {
					phandle = <0x109>;

					mux {
						function = "mdp_vsync_s";
						pins = "gpio78";
					};

					config {
						bias-pull-down;
						drive-strength = <0x02>;
						pins = "gpio78";
					};
				};
			};
		};
	};

