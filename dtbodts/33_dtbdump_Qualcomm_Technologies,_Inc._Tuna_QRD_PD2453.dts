	fragment@37 {
		target = <0xffffffff>;

		__overlay__ {

			motor_pin_init {
				phandle = <0x4e>;

				motor_int_active {
					phandle = <0x1e>;

					mux {
						pins = "gpio29";
						function = "gpio";
					};

					config {
						pins = "gpio29";
						drive-strength = <0x02>;
						bias-no-pull;
						input-enable;
					};
				};

				motor_rst_active {
					phandle = <0x1f>;

					mux {
						pins = "gpio146";
						function = "gpio";
					};

					config {
						pins = "gpio146";
						drive-strength = <0x02>;
						bias-pull-up;
						output-enable;
					};
				};
			};
		};
	};

	fragment@38 {
		target = <0xffffffff>;

		__overlay__ {
			status = "okay";
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			clock-frequency = <0x61a80>;
			mediatek,use-open-drain;

			aw86938_haptic@5A {
				status = "okay";
				compatible = "awinic,aw86938_haptic";
				reg = <0x5a>;
				pinctrl-names = "default";
				pinctrl-0 = <0x1e 0x1f>;
				irq-gpio = <0xffffffff 0x1d 0x00>;
				reset-gpio = <0xffffffff 0x92 0x00>;
				f0_pre = <0x6a4>;
				f0_cali_percent = [07];
				mode = [05];
				resistance_min = <0x1388>;
				resistance_max = <0x3a98>;
				f0_cali_freq_threshold = <0x78>;
				f0_test_freq_threshold = <0x96>;
				lra_info = <0x329>;
				awinic,vmax = <0x4f6>;
				disable-trigger;
				rtp_effects = <0x20>;
				scene_array = <0x21>;
				awinic,hbst_vmax = <0x1f40>;
				ram-file-name = "vivo_ram_haptic_0809_v2.bin";
				enable_constant_quick_start;
				line_impedance_volt = <0x12c>;
				dyna_cali_support;
				factory_f0_thrd = <0x14>;
				vibration_video_support;
				aw8693x_f0_cali_percent = [0f];
				aw8693x_gain_bypass = [01];
				aw8693x_uvlo_vol_default = [00];
				aw8693x_cont_smart_loop = [00];
				aw8693x_cont_drv1_lvl = [7f];
				aw8693x_cont_lra_vrms = <0x384>;
				aw8693x_cont_drv1_time = [04];
				aw8693x_cont_drv2_time = [38];
				aw8693x_cont_track_margin = [0f];
				aw8693x_cont_brk_time = [05];
				aw8693x_d2s_gain = [04];
				aw8693x_cont_brk_gain = [0a];
				aw8693x_cont_brk2_time = [08];
				aw8693x_d2s_gain2 = [05];
				aw8693x_cont_brk2_gain = [0b];
				aw8693x_duration_time = [14 1e 3c];
				aw8693x_trig_config = <0x01 0x20000 0x01 0x20000 0x01 0x20000>;
				aw8693x_bst_vol_default = <0x2134>;
				aw8693x_is_enabled_track_en;
				aw8693x_is_enabled_auto_bst;
			};
		};
	};

	fragment@39 {
		target = <0xffffffff>;

		__overlay__ {

			qupv3_se15_spi_pins {
				phandle = <0x4f>;

				qupv3_se15_spi_mosi_active {
					phandle = <0x22>;

					mux {
						pins = "gpio45";
						function = "qup2_se7_l1";
					};

					config {
						pins = "gpio45";
						drive-strength = <0x06>;
						bias-disable;
					};
				};

				qupv3_se15_spi_sleep {
					phandle = <0x23>;

					mux {
						pins = "gpio45";
						function = "gpio";
					};

					config {
						pins = "gpio45";
						drive-strength = <0x02>;
						bias-disable;
					};
				};
			};
		};
	};

	fragment@40 {
		target = <0xffffffff>;

		__overlay__ {
			status = "disabled";
		};
	};

	fragment@41 {
		target = <0xffffffff>;

		__overlay__ {
			pinctrl-names = "default", "sleep";
			pinctrl-0 = <0x22>;
			pinctrl-1 = <0x23>;
			status = "ok";

			irled_spi_38k@01 {
				status = "ok";
				compatible = "qcom_irled_spi";
				reg = <0x00>;
				spi-max-frequency = <0x1e8480>;
			};
		};
	};

	fragment@42 {
		target = <0xffffffff>;

		__overlay__ {

			tcard_sim {
				status = "ok";
				compatible = "card-detect";
				factory-test,sim1-card;
				factory-test,sim2-card;
				card-detect-sim1,gpios = <0xffffffff 0x57 0x00>;
				card-detect-sim2,gpios = <0xffffffff 0x5b 0x00>;
				vivo,sim1-reverse-detect;
				vivo,sim2-reverse-detect;
				vivo,tf-card-reverse-detect;
				pinctrl-names = "default";
				pinctrl-0 = <0xffffffff>;
				phandle = <0x50>;
			};

			st54spi_gpio {
				status = "ok";
				compatible = "st,st54spi_gpio";
				gpio-power_nreset = <0xffffffff 0x6f 0x00>;
				gpio-chip_en-std = <0xffffffff 0x3c 0x00>;
			};
		};
	};

	fragment@43 {
		target = <0xffffffff>;

		__overlay__ {
			status = "ok";
			qcom,clk-freq-out = <0x61a80>;
			#address-cells = <0x01>;
			#size-cells = <0x00>;

			nq@08 {
				compatible = "st,st21nfc";
				reg = <0x08>;
				vivo,nfc_support = <0x01>;
				vivo,boardversion_shift = <0x00>;
				vivo,boardversion_mask = <0x00>;
				vivo,boardversion_num = <0x00>;
				vivo,boardversions = "0";
				vivo,nfc_chip_type = "ST54L";
				irq-gpios = <0xffffffff 0x37 0x00>;
				reset-gpios = <0xffffffff 0x72 0x00>;
				clkreq-gpios = <0xffffffff 0x73 0x00>;
				interrupt-parent = <0xffffffff>;
				interrupts = <0x37 0x00>;
				interrupt-names = "nfc_irq";
			};
		};
	};

	fragment@44 {
		target = <0xffffffff>;

		__overlay__ {
			pinctrl-0 = <0x06 0xffffffff 0x24>;
			pinctrl-names = "default";
		};
	};

