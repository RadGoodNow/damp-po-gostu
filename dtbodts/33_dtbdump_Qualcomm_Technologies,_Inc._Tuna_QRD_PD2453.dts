/dts-v1/;

/ {
	qcom,pmic-id-size = <0x08>;
	qcom,pmic-id = <0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x4c>;
	model = "Qualcomm Technologies, Inc. Tuna QRD PD2453";
	compatible = "qcom,tuna-qrd", "qcom,tuna", "qcom,tunap-qrd", "qcom,tunap", "qcom,qrd";
	qcom,msm-id = <0x2a9 0x10000 0x28f 0x10000>;
	qcom,board-id = <0x0b 0x04>;

	fragment@0 {
		target = <0xffffffff>;

		__overlay__ {
			compatible = "qcom,ufs-phy-qmp-v4-niobe";
			vdda-phy-supply = <0xffffffff>;
			vdda-phy-max-microamp = <0x3406c>;
			vdda-phy-min-microvolt = <0xdea80>;
			vdda-pll-supply = <0xffffffff>;
			vdda-pll-max-microamp = <0x47a4>;
			vdd-phy-gdsc-supply = <0xffffffff>;
			vdda-qref-supply = <0xffffffff>;
			vdda-qref-max-microamp = <0xfbf4>;
			status = "ok";
		};
	};

	fragment@1 {
		target = <0xffffffff>;

		__overlay__ {
			vdd-hba-supply = <0xffffffff>;
			vcc-supply = <0xffffffff>;
			vcc-max-microamp = <0x124f80>;
			vccq-supply = <0xffffffff>;
			vccq-max-microamp = <0x124f80>;
			qcom,vccq-proxy-vote-supply = <0xffffffff>;
			qcom,vccq-proxy-vote-max-microamp = <0x124f80>;
			qcom,vddp-ref-clk-supply = <0xffffffff>;
			qcom,vddp-ref-clk-max-microamp = <0x64>;
			qcom,vccq-parent-supply = <0xffffffff>;
			qcom,vccq-parent-max-microamp = <0x33450>;
			status = "ok";
		};
	};

	fragment@2 {
		target = <0xffffffff>;

		__overlay__ {
			interrupt-parent = <0xffffffff>;
			interrupts = <0x00 0xb6 0x01 0x03>;
			interrupt-names = "usb_wcd";
			nvmem-cells = <0xffffffff>;
			nvmem-cell-names = "usb_mode";
		};
	};

	fragment@3 {
		target = <0xffffffff>;

		__overlay__ {
			vdd-supply = <0xffffffff>;
			qcom,vdd-voltage-level = <0x2d2a80 0x2d2a80>;
			qcom,vdd-current-level = <0x00 0xee5b6>;
			vdd-io-supply = <0x01>;
			qcom,vdd-io-voltage-level = <0x1b7740 0x2d2a80>;
			qcom,vdd-io-current-level = <0x00 0x16c6>;
			pinctrl-names = "default", "sleep";
			pinctrl-0 = <0xffffffff>;
			pinctrl-1 = <0xffffffff>;
			cd-gpios = <0xffffffff 0x27 0x01>;
			qcom,uses_level_shifter;
			status = "disabled";
		};
	};

	fragment@4 {
		target = <0xffffffff>;

		__overlay__ {
		};
	};

	fragment@5 {
		target = <0xffffffff>;

		__overlay__ {
			status = "ok";
			#address-cells = <0x01>;
			#size-cells = <0x00>;

			redriver@1c {
				compatible = "onnn,redriver";
				reg = <0x1c>;
				vdd-supply = <0xffffffff>;
				lane-channel-swap;
				eq = <0x4040404 0x5070705>;
				flat-gain = <0x3010103 0x30300>;
				output-comp = <0x3030303 0x3030303>;
				loss-match = <0x1030301 0x3030303>;
				phandle = <0x02>;
			};
		};
	};

	fragment@6 {
		target = <0xffffffff>;

		__overlay__ {
			pinctrl-names = "unused";
		};
	};

	fragment@7 {
		target = <0xffffffff>;

		__overlay__ {
			pinctrl-names = "default";
			pinctrl-0 = <0xffffffff>;
			gpios = <0xffffffff 0x7a 0x00>;
			ssusb_redriver = <0x02>;
			qcom,wcd_usbss = <0xffffffff>;
		};
	};

	fragment@8 {
		target = <0xffffffff>;

		__overlay__ {
			#address-cells = <0x02>;
			#size-cells = <0x00>;
			interrupt-controller;
			#interrupt-cells = <0x04>;

			qcom,pm7550ba@7 {
				compatible = "qcom,spmi-pmic";
				reg = <0x07 0x00>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;

				qcom,temp-alarm@a00 {
					compatible = "qcom,spmi-temp-alarm";
					reg = <0xa00>;
					interrupts = <0x07 0x0a 0x00 0x03>;
					#thermal-sensor-cells = <0x00>;
					io-channels = <0xffffffff 0x703>;
					io-channel-names = "thermal";
					phandle = <0x03>;
				};

				sdam@7000 {
					compatible = "qcom,spmi-sdam";
					reg = <0x7000>;
					phandle = <0x25>;
				};

				sdam@7100 {
					compatible = "qcom,spmi-sdam";
					reg = <0x7100>;
					phandle = <0x26>;
				};

				sdam@7200 {
					compatible = "qcom,spmi-sdam";
					reg = <0x7200>;
					phandle = <0x27>;
				};

				sdam@7300 {
					compatible = "qcom,spmi-sdam";
					reg = <0x7300>;
					phandle = <0x28>;
				};

				pinctrl@8800 {
					compatible = "qcom,pm7550ba-gpio";
					reg = <0x8800>;
					gpio-controller;
					#gpio-cells = <0x02>;
					interrupt-controller;
					#interrupt-cells = <0x02>;
					phandle = <0x1d>;

					sys_therm_7_gpio6 {

						sys_therm_7_gpio6_default {
							pins = "gpio6";
							bias-high-impedance;
							phandle = <0x06>;
						};
					};

					usb_conn_pro {

						usb_conn_pro_default {
							pins = "gpio3";
							function = "normal";
							power-source = <0x00>;
							output-low;
							phandle = <0x1c>;
						};
					};

					chg_ic_therm_gpio2 {

						chg_ic_therm_gpio2_default {
							pins = "gpio2";
							bias-high-impedance;
							phandle = <0x24>;
						};
					};
				};

				eusb2-repeater@fd00 {
					compatible = "qcom,pmic-eusb2-repeater";
					reg = <0xfd00>;
					status = "ok";
					vdd18-supply = <0xffffffff>;
					vdd3-supply = <0xffffffff>;
					qcom,param-override-seq = <0x00 0x50 0x0e 0x51 0x02 0x52 0x06 0x53 0x02 0x54 0x03 0x55 0x00 0x56 0x07 0x57 0x02 0x58 0x03 0x59 0x01 0x5a 0x02 0x5b>;
					qcom,param-override-seq-host = <0x00 0x50 0x08 0x51 0x02 0x52 0x06 0x53 0x01 0x54 0x00 0x55 0x00 0x56 0x04 0x57 0x02 0x58 0x03 0x59 0x01 0x5a 0x02 0x5b>;
					phandle = <0x0b>;
				};

				qcom,vibrator@df00 {
					compatible = "qcom,qpnp-vibrator-ldo";
					reg = <0xdf00>;
					qcom,vib-ldo-volt-uv = <0x2dc6c0>;
					qcom,disable-overdrive;
					status = "disabled";
					phandle = <0x29>;
				};

				qcom,amoled {
					compatible = "qcom,amoled-regulator";
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					status = "okay";
					phandle = <0x2a>;

					oledb@fa00 {
						reg = <0xfa00>;
						reg-names = "oledb_base";
						regulator-name = "oledb";
						regulator-min-microvolt = <0x4c4b40>;
						regulator-max-microvolt = <0x7a1200>;
						qcom,swire-control;
						phandle = <0x2b>;
					};

					ab@f900 {
						reg = <0xf900>;
						reg-names = "ab_base";
						regulator-name = "ab";
						regulator-min-microvolt = <0x4630c0>;
						regulator-max-microvolt = <0x4f5880>;
						qcom,swire-control;
						phandle = <0x2c>;
					};

					ibb@f800 {
						reg = <0xf800>;
						reg-names = "ibb_base";
						regulator-name = "ibb";
						regulator-min-microvolt = <0x155cc0>;
						regulator-max-microvolt = <0x64b540>;
						qcom,swire-control;
						regulator-allow-set-load;
						phandle = <0x2d>;
					};
				};

				qcom,amoled-ecm@f900 {
					compatible = "qcom,amoled-ecm";
					reg = <0xf900>;
					status = "disabled";
					nvmem-names = "amoled-ecm-sdam0", "amoled-ecm-sdam1", "amoled-ecm-sdam2";
					nvmem = <0xffffffff 0xffffffff 0xffffffff>;
					interrupt-names = "ecm-sdam0", "ecm-sdam1", "ecm-sdam2";
					interrupts = <0x00 0x7c 0x01 0x01 0x00 0x7d 0x01 0x01 0x00 0x98 0x01 0x01>;
					phandle = <0x2e>;
				};

				bcl@4700 {
					compatible = "qcom,bcl-v5";
					reg = <0x4700 0x100>;
					interrupts = <0x07 0x47 0x00 0x00 0x07 0x47 0x01 0x00 0x07 0x47 0x02 0x00>;
					interrupt-names = "bcl-lvl0", "bcl-lvl1", "bcl-lvl2";
					qcom,pmic7-threshold;
					#thermal-sensor-cells = <0x01>;
					nvmem-cells = <0xffffffff>;
					nvmem-cell-names = "sm1510_present";
					phandle = <0x04>;
				};

				bcl-soc {
					compatible = "qcom,msm-bcl-soc";
					#thermal-sensor-cells = <0x00>;
					phandle = <0x05>;
				};
			};
		};
	};

	fragment@9 {
		target = <0xffffffff>;

		__overlay__ {

			pm7550ba_tz {
				polling-delay-passive = <0x64>;
				polling-delay = <0x00>;
				thermal-governor = "step_wise";
				thermal-sensors = <0x03>;
				phandle = <0x2f>;

				trips {

					trip0 {
						temperature = <0x17318>;
						hysteresis = <0x00>;
						type = "passive";
						phandle = <0x30>;
					};

					trip1 {
						temperature = <0x1c138>;
						hysteresis = <0x00>;
						type = "hot";
						phandle = <0x31>;
					};

					trip2 {
						temperature = <0x23668>;
						hysteresis = <0x00>;
						type = "critical";
						phandle = <0x32>;
					};
				};
			};

			pm7550ba-ibat-lvl0 {
				polling-delay-passive = <0x00>;
				polling-delay = <0x00>;
				thermal-sensors = <0x04 0x00>;

				trips {

					ibat-lvl0 {
						temperature = <0x1b58>;
						hysteresis = <0xc8>;
						type = "passive";
						phandle = <0x33>;
					};
				};
			};

			pm7550ba-ibat-lvl1 {
				polling-delay-passive = <0x00>;
				polling-delay = <0x00>;
				thermal-sensors = <0x04 0x01>;

				trips {

					ibat-lvl1 {
						temperature = <0x2328>;
						hysteresis = <0xc8>;
						type = "passive";
						phandle = <0x34>;
					};
				};
			};

			vbat {
				polling-delay-passive = <0x00>;
				polling-delay = <0x00>;
				thermal-sensors = <0x04 0x02>;

				trips {

					vbat-lvl0 {
						temperature = <0xaf0>;
						hysteresis = <0x64>;
						type = "passive";
						phandle = <0x35>;
					};

					vbat-lvl1 {
						temperature = <0xa28>;
						hysteresis = <0x64>;
						type = "passive";
						phandle = <0x36>;
					};

					vbat-lvl2 {
						temperature = <0x8fc>;
						hysteresis = <0x64>;
						type = "passive";
						phandle = <0x37>;
					};
				};
			};

			pm7550ba-bcl-lvl0 {
				polling-delay-passive = <0x32>;
				polling-delay = <0x00>;
				thermal-sensors = <0x04 0x05>;

				trips {

					thermal-engine-trip {
						temperature = <0x64>;
						hysteresis = <0x00>;
						type = "passive";
					};

					thermal-hal-trip {
						temperature = <0x64>;
						hysteresis = <0x00>;
						type = "passive";
					};

					b-bcl-lvl0 {
						temperature = <0x01>;
						hysteresis = <0x01>;
						type = "passive";
						phandle = <0x07>;
					};
				};
			};

			pm7550ba-bcl-lvl1 {
				polling-delay-passive = <0x32>;
				polling-delay = <0x00>;
				thermal-sensors = <0x04 0x06>;

				trips {

					thermal-engine-trip {
						temperature = <0x64>;
						hysteresis = <0x00>;
						type = "passive";
					};

					thermal-hal-trip {
						temperature = <0x64>;
						hysteresis = <0x00>;
						type = "passive";
					};

					b-bcl-lvl1 {
						temperature = <0x01>;
						hysteresis = <0x01>;
						type = "passive";
						phandle = <0x08>;
					};
				};
			};

			pm7550ba-bcl-lvl2 {
				polling-delay-passive = <0x32>;
				polling-delay = <0x00>;
				thermal-sensors = <0x04 0x07>;

				trips {

					thermal-engine-trip {
						temperature = <0x64>;
						hysteresis = <0x00>;
						type = "passive";
					};

					thermal-hal-trip {
						temperature = <0x64>;
						hysteresis = <0x00>;
						type = "passive";
					};

					b-bcl-lvl2 {
						temperature = <0x01>;
						hysteresis = <0x01>;
						type = "passive";
						phandle = <0x09>;
					};
				};
			};

			socd {
				polling-delay-passive = <0x64>;
				polling-delay = <0x00>;
				thermal-sensors = <0x05>;

				trips {

					thermal-engine-trip {
						temperature = <0x64>;
						hysteresis = <0x00>;
						type = "passive";
					};

					thermal-hal-trip {
						temperature = <0x64>;
						hysteresis = <0x00>;
						type = "passive";
					};

					socd-trip {
						temperature = <0x60>;
						hysteresis = <0x00>;
						type = "passive";
						phandle = <0x0a>;
					};
				};
			};
		};
	};

	fragment@10 {
		target = <0xffffffff>;

		__overlay__ {

			qcom,pm7550ba-debug@7 {
				compatible = "qcom,spmi-pmic";
				reg = <0x07 0x00>;
				#address-cells = <0x02>;
				#size-cells = <0x00>;
				qcom,can-sleep;
			};
		};
	};

	fragment@11 {
		target = <0xffffffff>;

		__overlay__ {

			spmi@0 {
				reg = <0x00>;
				#address-cells = <0x02>;
				#size-cells = <0x00>;
				phandle = <0x38>;

				qcom,pm7550ba-debug@7 {
					compatible = "qcom,spmi-pmic";
					reg = <0x07 0x00>;
					qcom,can-sleep;
				};
			};

			i2c@106 {
				reg = <0x106>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				qcom,bus-type = "i2c";
				phandle = <0x39>;

				qcom,smb1398@34 {
					compatible = "qcom,i2c-pmic";
					reg = <0x34>;
					qcom,can-sleep;
					phandle = <0x3a>;
				};
			};

			spmi@200 {
				reg = <0x200>;
				#address-cells = <0x02>;
				#size-cells = <0x00>;
				qcom,bus-type = "spmi";
				phandle = <0x3b>;

				qcom,smb1510@d {
					compatible = "qcom,spmi-pmic";
					reg = <0x0d 0x00>;
					qcom,can-sleep;
					phandle = <0x3c>;
				};
			};
		};
	};

	fragment@12 {
		target = <0xffffffff>;

		__overlay__ {
			status = "ok";

			smb1398_1_iin {
				reg = <0x1063401>;
				label = "smb1393_1_iin";
			};

			smb1398_1_ichg {
				reg = <0x1063402>;
				label = "smb1393_1_ichg";
			};

			smb1398_1_die_temp {
				reg = <0x1063403>;
				label = "smb1393_1_die_temp";
			};
		};
	};

	fragment@13 {
		target = <0xffffffff>;

		__overlay__ {
			pinctrl-0 = <0x06 0xffffffff>;
			pinctrl-names = "default";

			pm7550ba_offset_ref {
				reg = <0x700>;
				label = "pm7550ba_offset_ref";
				qcom,pre-scaling = <0x01 0x01>;
			};

			pm7550ba_vref_1p25 {
				reg = <0x701>;
				label = "pm7550ba_vref_1p25";
				qcom,pre-scaling = <0x01 0x01>;
			};

			pm7550ba_die_temp {
				reg = <0x703>;
				label = "pm7550ba_die_temp";
				qcom,pre-scaling = <0x01 0x01>;
			};

			pm7550ba_vph_pwr {
				reg = <0x78e>;
				label = "pm7550ba_vph_pwr";
				qcom,pre-scaling = <0x01 0x03>;
			};

			pm7550ba_chg_temp {
				reg = <0x710>;
				label = "pm7550ba_chg_temp";
			};

			pm7550ba_iin_fb {
				reg = <0x717>;
				label = "pm7550ba_iin_fb";
			};

			pm7550ba_ichg_fb {
				reg = <0x7a1>;
				label = "pm7550ba_ichg_fb";
			};

			pm7550ba_sys_therm_7 {
				reg = <0x749>;
				label = "pm7550ba_sys_therm_7";
				qcom,adc-tm-type = <0x01>;
				qcom,ratiometric;
				qcom,hw-settle-time = <0xc8>;
				qcom,pre-scaling = <0x01 0x01>;
			};
		};
	};

	fragment@14 {
		target = <0xffffffff>;

		__overlay__ {
			qcom,thermal-mitigation-step = <0x7a120>;
			#cooling-cells = <0x02>;
		};
	};

	fragment@15 {
		target = <0xffffffff>;

		__overlay__ {

			sys-therm-7 {
				polling-delay-passive = <0x00>;
				polling-delay = <0x00>;
				thermal-sensors = <0xffffffff 0x749>;

				trips {

					active-config0 {
						temperature = <0x1e848>;
						hysteresis = <0x3e8>;
						type = "passive";
					};

					active-config1 {
						temperature = <0x1e848>;
						hysteresis = <0x3e8>;
						type = "passive";
					};
				};
			};
		};
	};

	fragment@16 {
		target = <0xffffffff>;

		__overlay__ {

			pm7550ba-ibat-lvl0 {

				trips {

					ibat-lvl0 {
						temperature = <0x2710>;
						phandle = <0x3d>;
					};
				};
			};

			pm7550ba-ibat-lvl1 {

				trips {

					ibat-lvl1 {
						temperature = <0x2cec>;
						phandle = <0x3e>;
					};
				};
			};

			pm7550ba-2s-ibat-lvl0 {
				polling-delay-passive = <0x00>;
				polling-delay = <0x00>;
				thermal-sensors = <0x04 0x08>;

				trips {

					ibat-2s-lvl0 {
						temperature = <0x1388>;
						hysteresis = <0xc8>;
						type = "passive";
						phandle = <0x3f>;
					};
				};
			};

			pm7550ba-2s-ibat-lvl1 {
				polling-delay-passive = <0x00>;
				polling-delay = <0x00>;
				thermal-sensors = <0x04 0x09>;

				trips {

					ibat-2s-lvl1 {
						temperature = <0x1b58>;
						hysteresis = <0xc8>;
						type = "passive";
						phandle = <0x40>;
					};
				};
			};

			pm7550ba-bcl-lvl0 {

				cooling-maps {

					lbat_0_nr_scg {
						trip = <0x07>;
						cooling-device = <0xffffffff 0x03 0x03>;
					};

					lbat_0_nr {
						trip = <0x07>;
						cooling-device = <0xffffffff 0x06 0x06>;
					};

					lbat_0_mdm_lte {
						trip = <0x07>;
						cooling-device = <0xffffffff 0x08 0x08>;
					};

					lbat_0_gpu {
						trip = <0x07>;
						cooling-device = <0xffffffff 0x02 0x02>;
					};
				};
			};

			pm7550ba-bcl-lvl1 {

				cooling-maps {

					lbat_1_nr_scg {
						trip = <0x08>;
						cooling-device = <0xffffffff 0x0a 0x0a>;
					};

					lbat_1_nr {
						trip = <0x08>;
						cooling-device = <0xffffffff 0x09 0x09>;
					};

					lbat_1_mdm_lte {
						trip = <0x08>;
						cooling-device = <0xffffffff 0x0a 0x0a>;
					};

					lbat_1_gpu {
						trip = <0x08>;
						cooling-device = <0xffffffff 0x03 0x03>;
					};
				};
			};

			pm7550ba-bcl-lvl2 {

				cooling-maps {

					lbat_2_gpu {
						trip = <0x09>;
						cooling-device = <0xffffffff 0x07 0x07>;
					};
				};
			};

			socd {

				cooling-maps {

					socd_apc1 {
