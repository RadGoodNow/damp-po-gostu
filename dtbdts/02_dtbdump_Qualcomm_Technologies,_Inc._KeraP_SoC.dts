			#mbox-cells = <0x01>;
			interrupts = <0x00 0x3e 0x04>;
			phandle = <0x8c>;
		};

		qcom,scmi {
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			compatible = "arm,scmi";
			mboxes = <0x8c 0x00>;
			mbox-names = "tx";
			shmem = <0x8d>;
			phandle = <0x36d>;

			protocol@80 {
				reg = <0x80>;
				#clock-cells = <0x01>;
				phandle = <0x36e>;
			};
		};

