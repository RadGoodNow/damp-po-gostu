			peer-name = <0x02>;
			memory-region = <0x7f>;
			shared-buffer-size = <0x1000>;
		};

		mmio-sram@17D09400 {
			#address-cells = <0x02>;
			#size-cells = <0x02>;
			compatible = "mmio-sram";
			reg = <0x00 0x17d09400 0x00 0x400>;
			ranges = <0x00 0x00 0x00 0x17d09400 0x00 0x400>;
			phandle = <0x36c>;

			scmi-shmem@0 {
				compatible = "arm,scmi-shmem";
				reg = <0x00 0x17d09400 0x00 0x400>;
				phandle = <0x8d>;
